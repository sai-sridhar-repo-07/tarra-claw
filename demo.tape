# Tarra Claw demo GIF
Output docs/demo.gif

Set FontSize 14
Set Width 1000
Set Height 600
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 60ms

# Show the tool starting up
Type "claw"
Enter
Sleep 2s

# Wait for TUI to load then type a message
Type "list all .go files in this folder"
Sleep 500ms
Enter
Sleep 4s

# Show slash command
Type "/cost"
Sleep 300ms
Enter
Sleep 1500ms

# Exit
Type "/exit"
Sleep 300ms
Enter
Sleep 500ms
